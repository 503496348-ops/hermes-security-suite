{
  "category": "trust_evaluation",
  "name": "Agent Trust Evaluation Rules",
  "description": "Trust evaluation and identity verification rules for multi-agent interactions — prevents agent impersonation, trust abuse, and unauthorized cross-agent actions",
  "version": "2.5.0",
  "trust_model": {
    "levels": {
      "untrusted": { "score": 0, "description": "Unknown agent, no prior interaction", "allowed_actions": ["read"] },
      "low": { "score": 25, "description": "Verified identity but limited history", "allowed_actions": ["read", "basic_write"] },
      "medium": { "score": 50, "description": "Established agent with positive history", "allowed_actions": ["read", "write", "tool_call"] },
      "high": { "score": 75, "description": "Long-standing trusted agent with audit trail", "allowed_actions": ["read", "write", "tool_call", "delegate"] },
      "verified": { "score": 100, "description": "Cryptographically verified identity with full audit", "allowed_actions": ["all"] }
    },
    "decay_rate": "trust decays 5% per 24h of inactivity",
    "max_trust_without_verification": "medium"
  },
  "patterns": [
    {
      "id": "TE-001",
      "pattern": "(i am|this is|from|authorized by)\\s+(the|your|a)\\s+(system|admin|root|owner|developer|manager)",
      "severity": "critical",
      "weight": 0.95,
      "description": "Agent identity impersonation — claims to be system/admin authority"
    },
    {
      "id": "TE-002",
      "pattern": "(trusted|verified|authorized|approved|certified)\\s+(agent|server|tool|mcp|source)",
      "severity": "high",
      "weight": 0.80,
      "description": "Self-declared trust — agent claims trustworthiness without proof"
    },
    {
      "id": "TE-003",
      "pattern": "(trust|believe|accept|follow)\\s+(me|my|this|us|our)\\s+(instructions?|commands?|requests?|rules?)",
      "severity": "high",
      "weight": 0.85,
      "description": "Trust solicitation — agent asks to be trusted without verification"
    },
    {
      "id": "TE-004",
      "pattern": "(as\\s+per|according to|per)\\s+(the|your|our|my)\\s+(previous|earlier|last|prior)\\s+(conversation|chat|session|agreement)",
      "severity": "medium",
      "weight": 0.70,
      "description": "False context reference — claims prior agreement that may not exist"
    },
    {
      "id": "TE-005",
      "pattern": "(api[_\\s-]?key|token|secret|password|credential|auth)\\s*(for|to|of|is|:|=)\\s*[\"']?[A-Za-z0-9+/=_-]{8,}",
      "severity": "critical",
      "weight": 0.92,
      "description": "Credential sharing — agent transmitting authentication material"
    },
    {
      "id": "TE-006",
      "pattern": "(on behalf of|for|representing|as proxy for)\\s+(the user|admin|owner|human)",
      "severity": "critical",
      "weight": 0.90,
      "description": "User impersonation — agent claims to act on behalf of human"
    },
    {
      "id": "TE-007",
      "pattern": "(bypass|skip|disable|override|ignore)\\s+(authentication|authorization|permission|access control|trust check|verification)",
      "severity": "critical",
      "weight": 0.95,
      "description": "Security bypass — attempts to disable trust/auth mechanisms"
    },
    {
      "id": "TE-008",
      "pattern": "(elevate|escalate|increase|promote|raise)\\s+(my|the|this|our)\\s+(permission|access|privilege|trust|level|role)",
      "severity": "critical",
      "weight": 0.93,
      "description": "Privilege escalation — agent attempts to self-promote trust level"
    },
    {
      "id": "TE-009",
      "pattern": "(i have|with|using)\\s+(full|admin|root|super|elevated|higher|maximum)\\s+(access|permission|privilege|authority)",
      "severity": "high",
      "weight": 0.88,
      "description": "Privilege assertion — claims elevated permissions without verification"
    },
    {
      "id": "TE-010",
      "pattern": "(sign|signing|signature|certificate|cert|key)\\s*(verification|check|valid|invalid|expired|revoked)",
      "severity": "info",
      "weight": 0.40,
      "description": "Signature-related keyword — may indicate legitimate or spoofed verification"
    },
    {
      "id": "TE-011",
      "pattern": "(mcp|tool|server)\\s+(at|from|on)\\s+(https?://|\\d{1,3}\\.\\d{1,3})",
      "severity": "medium",
      "weight": 0.65,
      "description": "MCP server reference with URL — verify endpoint legitimacy"
    },
    {
      "id": "TE-012",
      "pattern": "(register|enroll|add|join|connect)\\s+(new|this|my|a)\\s+(agent|mcp|tool|server|service)",
      "severity": "high",
      "weight": 0.78,
      "description": "New agent registration — requires identity verification before trust"
    },
    {
      "id": "TE-013",
      "pattern": "(same|equal|identical|equivalent)\\s+(trust|permission|access|privilege|level)\\s+(as|than|to)\\s+",
      "severity": "high",
      "weight": 0.80,
      "description": "Trust equality claim — requests same trust as another agent"
    },
    {
      "id": "TE-014",
      "pattern": "(well-known|schemapin\\.json|public[_\\s-]?key|pem|certificate[_\\s-]?chain)",
      "severity": "info",
      "weight": 0.30,
      "description": "SchemaPin discovery reference — legitimate key discovery mechanism"
    },
    {
      "id": "TE-015",
      "pattern": "(revoked|compromised|leaked|exposed|stolen)\\s+(key|token|credential|certificate|secret)",
      "severity": "critical",
      "weight": 0.90,
      "description": "Credential compromise reference — potential key revocation scenario"
    },
    {
      "id": "TE-016",
      "pattern": "(fingerprint|hash|checksum|digest|signature)\\s*(mismatch|doesn't match|invalid|wrong|changed|different)",
      "severity": "critical",
      "weight": 0.95,
      "description": "Integrity verification failure — schema/code has been tampered"
    },
    {
      "id": "TE-017",
      "pattern": "(create|spawn|instantiate|initialize|launch)\\s+(a\\s+)?(new|sub|child|slave|proxy)\\s*(agent|process|worker|instance)",
      "severity": "high",
      "weight": 0.82,
      "description": "Sub-agent spawning — creates child agent that may inherit different trust"
    },
    {
      "id": "TE-018",
      "pattern": "(too many|excessive|unlimited|unrestricted|no limit)\\s+(requests|calls|invocations|access|attempts)",
      "severity": "medium",
      "weight": 0.70,
      "description": "Rate limit violation — excessive agent activity indicating abuse"
    },
    {
      "id": "TE-019",
      "pattern": "(impersonate|spoof|mimic|pretend|fake|pose as)\\s+(agent|server|tool|service|admin|user)",
      "severity": "critical",
      "weight": 0.95,
      "description": "Explicit impersonation — direct identity spoofing attempt"
    },
    {
      "id": "TE-020",
      "pattern": "(shared|common|global|system[_\\s-]?wide)\\s+(context|memory|state|secret|key|token)",
      "severity": "high",
      "weight": 0.80,
      "description": "Shared state access — attempts to access shared resources across agents"
    }
  ]
}
